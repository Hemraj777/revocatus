{
  "manifest_version": 3,
  "name": "Revocatus - Facebook Reaction Cleaner",
  "version": "1.0.0",
  "description": "Remove Facebook likes and reactions in bulk from Activity Log.",
  "icons": {
    "48": "icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Revocatus"
  },
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "host_permissions": [
    "*://*.facebook.com/*"
  ]
}
